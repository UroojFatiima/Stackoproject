# Where notification emails are delivered
NOTIFY_EMAIL=sani123456@protonmail.com

# ─── Option A: Resend (easiest for live deployment) ───
# 1. Create free account at https://resend.com
# 2. Get API key and paste below
# 3. Use RESEND_FROM with a verified domain (or resend.dev for testing)
RESEND_API_KEY=
RESEND_FROM=Stacko <onboarding@resend.dev>

# ─── Option B: SMTP (Gmail, Outlook, ProtonMail Bridge, etc.) ───
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Stacko <noreply@yourdomain.com>

# Example Gmail (requires App Password — NOT your normal password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-16-char-app-password
